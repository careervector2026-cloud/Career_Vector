# --- Maven & Build Results ---
target/
*.class
*.jar
*.war
*.ear
*.log
*.zip
*.tar.gz
*.rar
*.gz

# --- Maven Wrapper ---
# We generally want to COMMIT the wrapper jar so builds are reproducible/offline capable.
# If you prefer to download it every time, uncomment the next line:
# .mvn/wrapper/maven-wrapper.jar

# --- Secrets & Environment (CRITICAL) ---
# Never push your database passwords or API keys
.env
.env.local
.env.*.local
secret.properties

# --- Java Crash Logs ---
hs_err_pid*
replay_pid*

# --- IDE: IntelliJ IDEA (Leftovers) ---
.idea/
*.iws
*.iml
*.ipr
out/

# --- IDE: VS Code ---
.vscode/

# --- IDE: Eclipse / Spring Tool Suite (STS) ---
.metadata/
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache
bin/
tmp/

# --- IDE: NetBeans ---
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/

# --- OS System Files (Junk) ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Docker ---
# If you build docker locally, you don't want to commit the image data context if it generates files
docker-compose.override.yml